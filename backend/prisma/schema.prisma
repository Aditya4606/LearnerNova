generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id             String       @id @default(uuid())
  email          String       @unique
  username       String       @unique
  password       String
  role           Role         @default(LEARNER)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  coursesCreated Course[]     @relation("InstructorCourses")
  enrollments    Enrollment[]
  reviews        Review[]
}

model Course {
  id           String       @id @default(uuid())
  title        String
  description  String?
  isPublished  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  createdBy    String
  duration     String?
  lessonsCount Int          @default(0)
  tags         String[]     @default([])
  views        Int          @default(0)
  imageUrl     String?
  updatedAt    DateTime     @default(now()) @updatedAt
  website      String?
  price        Float        @default(0)
  visibility   String       @default("everyone")
  accessRule   String       @default("open")
  instructor   User         @relation("InstructorCourses", fields: [createdBy], references: [id])
  enrollments  Enrollment[]
  lessons      Lesson[]
  quizzes      Quiz[]
  reviews      Review[]
}

model Lesson {
  id            String   @id @default(uuid())
  title         String
  content       String?
  type          String   @default("video")
  status        String   @default("not-started")
  order         Int      @default(0)
  courseId      String
  description   String?
  responsible   String?
  duration      String?
  allowDownload Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime     @updatedAt
  course        Course       @relation(fields: [courseId], references: [id])
  attachments   Attachment[]
}

model Attachment {
  id        String   @id @default(uuid())
  title     String
  type      String
  url       String
  lessonId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lesson    Lesson   @relation(fields: [lessonId], references: [id])
}

model Quiz {
  id        String     @id @default(uuid())
  title     String
  courseId  String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  rewards   Json?      
  questions Question[]
  course    Course     @relation(fields: [courseId], references: [id])
}

model Question {
  id      String   @id @default(uuid())
  text    String
  options String[]
  answer  Int
  quizId  String
  quiz    Quiz     @relation(fields: [quizId], references: [id])
}

model Enrollment {
  id          String    @id @default(uuid())
  userId      String
  courseId    String
  progress    Int       @default(0)
  status      String    @default("yet_to_start")
  startedAt   DateTime?
  completedAt DateTime?
  timeSpent   Int       @default(0)
  createdAt   DateTime  @default(now())
  course      Course    @relation(fields: [courseId], references: [id])
  user        User      @relation(fields: [userId], references: [id])

  @@unique([userId, courseId])
}

enum Role {
  ADMIN
  INSTRUCTOR
  LEARNER
}

model Review {
  id        String   @id @default(uuid())
  rating    Int
  comment   String?
  userId    String
  courseId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id])
  course    Course   @relation(fields: [courseId], references: [id])

  @@unique([userId, courseId])
}
